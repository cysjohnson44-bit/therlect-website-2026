{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "pnpm install && pnpm run build"
  },
  "deploy": {
    "startCommand": "node dist/index.js",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000
  },
  "variables": {
    "NODE_ENV": "production",
    "PORT": "3000"
  }
}
